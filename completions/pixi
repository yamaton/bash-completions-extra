_pixi_workspace_requirespixi()
{
    local cmd i subcommands
    local subcommands=" get set unset verify help"

    for (( i=1; i < cword; i++ )); do
        if [[ " ${subcommands[*]} " == *" ${words[i]} "* ]]; then
            cmd=${words[i]}
            break
        fi
    done

    case "$cmd" in
        get) _pixi_workspace_requirespixi_get
            return
            ;;

        set) _pixi_workspace_requirespixi_set
            return
            ;;

        unset) _pixi_workspace_requirespixi_unset
            return
            ;;

        verify) _pixi_workspace_requirespixi_verify
            return
            ;;

        help) _pixi_workspace_requirespixi_help
            return
            ;;

    esac

    local word_list=" get set unset verify help -m --manifest-path -w --workspace -h --help -v --verbose -q --quiet --color --no-progress"
    COMPREPLY=( $(compgen -W "${word_list}" -- "$cur") )
}

